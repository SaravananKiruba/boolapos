<mah:MetroWindow x:Class="Page_Navigation_App.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Page_Navigation_App.View"
        xmlns:viewModel="clr-namespace:Page_Navigation_App.ViewModel"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"        Title="Boola POS Login" 
        Height="450" 
        Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource MahApps.Brushes.ThemeBackground}">
    
    <mah:MetroWindow.Resources>
        <Style x:Key="LoginTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MahApps.Styles.TextBox}">
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox" BasedOn="{StaticResource MahApps.Styles.PasswordBox}">
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="LoginButtonStyle" TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Accent}">
            <Setter Property="Margin" Value="0,15,0,0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </mah:MetroWindow.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>
          <!-- Left side with logo and welcome message -->
        <Grid Grid.Column="0" Background="{StaticResource MahApps.Brushes.Accent}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="/Images/BOOLA LOGO.png" Width="150" Height="150" Margin="0,0,0,20"/>
                <TextBlock Text="Welcome to" FontSize="22" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Boola POS System" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Please login to continue" FontSize="16" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
        
        <!-- Right side with login form -->
        <Grid Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
            <StackPanel Margin="30" VerticalAlignment="Center">
                <TextBlock Text="Login" FontSize="26" FontWeight="Bold" Margin="0,0,0,30"/>
                
                <TextBlock Text="Username" FontSize="14"/>
                <TextBox Style="{StaticResource LoginTextBoxStyle}" 
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                
                <TextBlock Text="Password" FontSize="14"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource LoginPasswordBoxStyle}"/>
                
                <TextBlock Text="{Binding LoginMessage}" 
                         Foreground="Red" 
                         TextWrapping="Wrap"
                         Visibility="{Binding LoginMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                
                <Button Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=PasswordBox}"
                        Content="Login" 
                        Style="{StaticResource LoginButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</mah:MetroWindow>